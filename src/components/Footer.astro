---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Ajay Phatak. All rights reserved.
	<div class="footer-links">
		<a href="/about/">About</a>
		<a href="/privacy/">Privacy Policy</a>
		<a href="https://elections.ajaycent.com">Election Tracker</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		margin-top: 1em;
	}
	.footer-links a {
		color: rgb(var(--gray));
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
