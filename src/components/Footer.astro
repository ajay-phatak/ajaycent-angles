---
const today = new Date();
---

<footer>
	<div class="social">
		<a href="https://ajay-phatak.github.io/">GitHub</a>
		<a href="https://www.linkedin.com/in/ajay-phatak-1b0563123/">LinkedIn</a>
		<a href="https://www.instagram.com/ajay.phatak/">Instagram</a>
		<a href="mailto:ajay.phatak2@gmail.com">Email</a>
	</div>
	<p>&copy; {today.getFullYear()} Ajay Phatak</p>
</footer>
<style>
	footer {
		padding: 2.5em 1em;
		border-top: 1px solid var(--rule);
		color: var(--ink-soft);
		text-align: center;
		font-size: 0.85rem;
	}
	.social {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		margin-bottom: 1em;
	}
	.social a { color: var(--ink-soft); text-decoration: none; }
	.social a:hover { color: var(--accent); }
	footer p { margin: 0; }
</style>
