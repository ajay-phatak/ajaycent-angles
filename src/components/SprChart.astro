---
// Strategic Petroleum Reserve vs. WTI futures/spot, Jan 2025 – Jul 2026.
---

<figure class="chart">
	<div class="chart-legend">
		<span><i class="swatch line-teal"></i>Strategic Petroleum Reserve</span>
		<span><i class="swatch line-warm"></i>WTI 12-month futures</span>
		<span><i class="swatch line-warm-faint"></i>WTI spot</span>
		<span><i class="swatch band"></i>Usable reserve</span>
	</div>

	<div class="chart-canvas">
		<canvas
			id="spr-chart"
			role="img"
			aria-label="The U.S. Strategic Petroleum Reserve against WTI oil prices from January 2025 to July 2026. The reserve refills to a peak of 415 million barrels in early March 2026, then falls to 316.5 million by July. WTI spot peaks above $102 in May 2026 while 12-month futures never exceed $76, a backwardation of more than $26."
		>
			The SPR fell from 415 million barrels to 316.5 million between March and July 2026,
			consuming about 61% of the reserve usable above the statutory floor. WTI spot peaked
			at $102 while 12-month futures stayed below $76.
		</canvas>
	</div>

	<ol class="chart-key">
		<li><b>1</b> 12-Day War · Jun 2025</li>
		<li><b>2</b> Operation Epic Fury · Feb 28 2026</li>
		<li><b>3</b> 172M-bbl release · Mar 11</li>
		<li><b>4</b> Ceasefire · Apr 8</li>
	</ol>

	<figcaption>
		Reserve levels and WTI spot: U.S. Energy Information Administration (weekly SPR stocks;
		Cushing WTI monthly average). Futures: NYMEX settlement for the contract expiring twelve
		months after each observation month — contracts dated before August 2025 have expired and
		are no longer published, so that series begins there. July 2026 spot is month-to-date.
		Statutory floor of 252.4M barrels per 42 U.S.C. §6241.
	</figcaption>
</figure>

<style>
	.chart {
		margin: 2.5em 0;
		padding: 0;
	}
	.chart-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.2em;
		margin-bottom: 0.9em;
		font-family: var(--font-serif);
		font-size: 0.78rem;
		color: var(--ink-soft);
	}
	.chart-legend span {
		display: flex;
		align-items: center;
		gap: 0.45em;
	}
	.swatch {
		display: inline-block;
		width: 18px;
		flex-shrink: 0;
	}
	.line-teal { height: 3px; background: var(--accent); }
	.line-warm { height: 3px; background: #b06135; }
	.line-warm-faint { height: 2px; background: #b06135; opacity: 0.45; }
	.band {
		height: 11px;
		background: color-mix(in oklch, var(--accent) 10%, transparent);
		border-top: 1px dashed var(--accent);
		border-bottom: 1px dashed var(--accent);
	}
	:global([data-theme='dark']) .line-warm,
	:global([data-theme='dark']) .line-warm-faint { background: #d98f63; }

	.chart-canvas {
		position: relative;
		width: 100%;
		height: 400px;
	}
	.chart-key {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em 1.4em;
		margin: 0.9em 0 0;
		padding: 0;
		font-family: var(--font-serif);
		font-size: 0.78rem;
		color: var(--ink-soft);
	}
	.chart-key b {
		color: var(--ink);
		margin-right: 0.35em;
	}
	figcaption {
		margin-top: 0.9em;
		font-family: var(--font-serif);
		font-size: 0.72rem;
		font-style: italic;
		line-height: 1.5;
		color: var(--ink-soft);
	}
	@media (max-width: 720px) {
		.chart-canvas { height: 320px; }
	}
	@media (max-width: 560px) {
		.chart-canvas { height: 380px; }
	}
</style>

<script>
	import Chart from 'chart.js/auto';
	import { palette, onThemeChange } from '../scripts/chart-theme.js';

	const labels = [
		"Jan '25", 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
		"Jan '26", 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul',
	];
	const spr = [
		393.8, 395.3, 395.6, 396.7, 399.1, 402.1, 403.0, 403.0, 405.2, 407.0, 410.4, 411.9,
		413.5, 415.2, 415.4, 413.3, 392.7, 349.2, 316.5,
	];
	/*
	  Spot: EIA Cushing WTI monthly average (RWTCm). July 2026 is the
	  month-to-date mean of NYMEX front-month, since EIA hasn't closed the month.
	  Futures: NYMEX settlement for the contract expiring 12 months after each
	  observation month. Contracts dated before Aug 2025 have expired and are no
	  longer retrievable, so the forward series starts there.
	*/
	const spot = [
		75.7, 71.5, 68.2, 63.5, 62.2, 68.2, 68.4, 64.9, 64.0, 60.9, 60.1, 58.0,
		60.0, 64.5, 91.4, 100.3, 102.1, 84.8, 75.7,
	];
	const futures = [
		null, null, null, null, null, null, null, 61.8, 62.0, 59.5, 59.1, 57.5,
		58.8, 61.5, 70.9, 72.9, 75.7, 71.9, 69.9,
	];

	const WAR = 14;
	const LAST = spr.length - 1;
	const FLOOR = 252.4;
	const PEAK = 415.4;

	const thresholds = [
		{ y: 727, label: 'All-time high · 727M', short: '727M all-time high', shortest: '727M high', key: false },
		{ y: PEAK, label: 'Pre-war peak · 415M', short: '415M pre-war peak', shortest: '415M peak', key: false },
		{ y: FLOOR, label: 'Statutory drawdown floor · 252M', short: '252M statutory floor', shortest: '252M floor', key: true },
		{ y: 180, label: 'IEA 90-day minimum · 180M', short: '180M IEA minimum', shortest: '180M IEA', key: false },
	];
	const events = [
		{ x: 5, n: '1' },
		{ x: 13.9, n: '2' },
		{ x: 14.45, n: '3' },
		{ x: 15.25, n: '4' },
	];

	const NARROW = () => window.matchMedia('(max-width: 560px)').matches;

	// Stagger event bubbles that land too close together in x (only relevant
	// at narrow widths, where the plot area is a few hundred pixels wide).
	function computeEventRows(ch) {
		const { scales } = ch;
		let prevX = null;
		let prevRow = 0;
		let maxRow = 0;
		const rows = events.map((e) => {
			const x = scales.x.getPixelForValue(e.x);
			const row = prevX !== null && Math.abs(x - prevX) < 22 ? prevRow + 1 : 0;
			prevX = x;
			prevRow = row;
			maxRow = Math.max(maxRow, row);
			return row;
		});
		return { rows, maxRow };
	}

	function render() {
		const canvas = document.getElementById('spr-chart');
		if (!canvas) return;
		const c = palette();
		const narrow = NARROW();
		Chart.getChart(canvas)?.destroy();

		const overlay = {
			id: 'sprOverlay',
			beforeDatasetsDraw(ch) {
				const { ctx, chartArea: a, scales } = ch;
				if (!a) return;
				ctx.save();
				ctx.fillStyle = c.band;
				const top = scales.yL.getPixelForValue(PEAK);
				ctx.fillRect(a.left, top, a.right - a.left, scales.yL.getPixelForValue(FLOOR) - top);
				ctx.restore();
			},
			afterDraw(ch) {
				const { ctx, chartArea: a, scales } = ch;
				if (!a) return;
				ctx.save();

				const bubbleR = narrow ? 7 : 8;
				const numFont = narrow ? 9 : 10;
				const rows = narrow ? computeEventRows(ch).rows : events.map(() => 0);
				const bubbles = events.map((e, i) => ({
					x: scales.x.getPixelForValue(e.x),
					cy: narrow ? a.top + 6 + rows[i] * 19 : a.top + 6,
				}));

				thresholds.forEach((t) => {
					const y = scales.yL.getPixelForValue(t.y);
					ctx.setLineDash([5, 4]);
					ctx.lineWidth = t.key ? 1.75 : 1;
					ctx.strokeStyle = t.key ? c.teal : c.inkSoft;
					ctx.beginPath();
					ctx.moveTo(a.left, y);
					ctx.lineTo(a.right, y);
					ctx.stroke();
					ctx.setLineDash([]);

					let text = t.label;
					const fontSize = narrow ? (t.key ? 9.5 : 9) : t.key ? 11 : 10.5;
					ctx.font = `italic ${fontSize}px ${c.serif}`;
					if (narrow) {
						text = t.short;
						const maxWidth = a.right - a.left - 14;
						if (ctx.measureText(text).width > maxWidth) {
							text = t.shortest;
						}
					}
					ctx.fillStyle = t.key ? c.teal : c.inkSoft;
					ctx.textAlign = 'left';

					/*
					  Labels normally sit above their line, but the topmost one runs
					  under the event bubbles once the plot narrows. Drop just the
					  colliding label below its line rather than shifting them all —
					  below-the-line is worse everywhere else, where the label would
					  then cross the series it annotates.
					*/
					const x0 = a.left + 7;
					const x1 = x0 + ctx.measureText(text).width;
					const hits =
						narrow &&
						bubbles.some(
							(b) =>
								b.x + bubbleR > x0 &&
								b.x - bubbleR < x1 &&
								b.cy + bubbleR > y - 3 - fontSize &&
								b.cy - bubbleR < y - 3,
						);
					if (hits) {
						ctx.textBaseline = 'top';
						ctx.fillText(text, x0, y + 3);
					} else {
						ctx.textBaseline = 'bottom';
						ctx.fillText(text, x0, y - 3);
					}
				});

				events.forEach((e, i) => {
					const { x, cy } = bubbles[i];
					const connectorTop = narrow ? cy + bubbleR + 2 : a.top + 13;
					ctx.setLineDash([3, 4]);
					ctx.lineWidth = 1;
					ctx.strokeStyle = c.inkSoft;
					ctx.beginPath();
					ctx.moveTo(x, connectorTop);
					ctx.lineTo(x, a.bottom);
					ctx.stroke();
					ctx.setLineDash([]);
					ctx.beginPath();
					ctx.arc(x, cy, bubbleR, 0, Math.PI * 2);
					ctx.fillStyle = c.bg;
					ctx.fill();
					ctx.lineWidth = 1.25;
					ctx.strokeStyle = c.inkSoft;
					ctx.stroke();
					ctx.font = `500 ${numFont}px ${c.serif}`;
					ctx.fillStyle = c.ink;
					ctx.textAlign = 'center';
					ctx.textBaseline = 'middle';
					ctx.fillText(e.n, x, cy + 0.5);
				});
				ctx.restore();
			},
			afterDatasetsDraw(ch) {
				const { ctx, scales } = ch;
				ctx.save();
				ctx.font = `500 ${narrow ? 10 : 11}px ${c.serif}`;
				ctx.fillStyle = c.teal;
				ctx.textAlign = 'right';
				ctx.textBaseline = 'top';
				ctx.fillText(
					'316.5M',
					scales.x.getPixelForValue(LAST) - 4,
					scales.yL.getPixelForValue(spr[LAST]) + 8,
				);
				ctx.restore();
			},
		};

		const chart = new Chart(canvas, {
			type: 'line',
			data: {
				labels,
				datasets: [
					{
						label: 'SPR',
						data: spr,
						yAxisID: 'yL',
						borderColor: c.teal,
						borderWidth: 2.75,
						tension: 0.15,
						pointRadius: (ctx) => (ctx.dataIndex === LAST ? 4.5 : 0),
						pointBackgroundColor: c.teal,
						pointBorderColor: c.bg,
						pointBorderWidth: 2,
						segment: { borderColor: (ctx) => (ctx.p0DataIndex >= WAR ? c.teal : c.tealDim) },
					},
					{
						label: 'WTI 12-mo futures',
						data: futures,
						yAxisID: 'yR',
						borderColor: c.warm,
						borderWidth: 2.5,
						tension: 0.2,
						pointRadius: 0,
					},
					{
						label: 'WTI spot',
						data: spot,
						yAxisID: 'yR',
						borderColor: c.warmFaint,
						borderWidth: 1.25,
						tension: 0.2,
						pointRadius: 0,
					},
				],
			},
			options: {
				responsive: true,
				maintainAspectRatio: false,
				// Draw immediately: an entry animation adds nothing to a reference chart,
				// and it means the chart is never blank while off-screen or reduced-motion.
				animation: false,
				// Narrow guess covers the worst case (3 clustered events staggered
				// to 2 extra rows); adjusted down after layout if not needed.
				layout: { padding: { top: narrow ? 58 : 20, right: 6 } },
				interaction: { mode: 'index', intersect: false },
				plugins: {
					legend: { display: false },
					tooltip: {
						backgroundColor: c.tooltipBg,
						titleColor: c.ink,
						bodyColor: c.inkSoft,
						borderColor: c.rule,
						borderWidth: 1,
						titleFont: { family: c.serif },
						bodyFont: { family: c.serif },
						callbacks: {
							label: (x) =>
								`${x.dataset.label}: ` +
								(x.dataset.yAxisID === 'yL'
									? `${x.parsed.y.toFixed(1)}M bbl`
									: `$${x.parsed.y.toFixed(0)}`),
						},
					},
				},
				scales: {
					yL: {
						position: 'left',
						min: 150,
						max: 760,
						title: {
							display: !narrow,
							text: 'Strategic reserve (million barrels)',
							color: c.teal,
							font: { family: c.serif, size: 12 },
						},
						ticks: {
							color: c.inkSoft,
							font: { family: c.serif, size: narrow ? 10 : 11 },
							callback: (v) => `${v}M`,
						},
						grid: { color: c.rule, drawTicks: false },
						border: { display: false },
					},
					yR: {
						position: 'right',
						min: 50,
						max: 110,
						title: {
							display: !narrow,
							text: 'WTI ($ / barrel)',
							color: c.warm,
							font: { family: c.serif, size: 12 },
						},
						ticks: {
							color: c.inkSoft,
							font: { family: c.serif, size: narrow ? 10 : 11 },
							callback: (v) => `$${v}`,
						},
						grid: { display: false },
						border: { display: false },
					},
					x: {
						ticks: {
							color: c.inkSoft,
							font: { family: c.serif, size: narrow ? 10 : 11 },
							autoSkip: false,
							maxRotation: 0,
							callback: (_v, i) =>
								narrow ? ([0, 6, 12, 18].includes(i) ? labels[i] : '') : i % 2 === 0 ? labels[i] : '',
						},
						grid: { display: false },
						border: { color: c.rule },
					},
				},
			},
			plugins: [overlay],
		});

		if (narrow) {
			const { maxRow } = computeEventRows(chart);
			const neededTop = 20 + 19 * maxRow;
			if (neededTop !== chart.options.layout.padding.top) {
				chart.options.layout.padding.top = neededTop;
				chart.update('none');
			}
		}
	}

	/*
	  The theme toggle writes data-theme during load, which can land mid-init and
	  race Chart.js. Debounce so we always settle on one build of the chart.
	*/
	let queued;
	function scheduleRender() {
		clearTimeout(queued);
		queued = setTimeout(() => {
			try {
				render();
			} catch (err) {
				console.error('[SprChart] render failed', err);
			}
		}, 50);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', scheduleRender);
	} else {
		scheduleRender();
	}
	onThemeChange(scheduleRender);
	window.matchMedia('(max-width: 560px)').addEventListener('change', scheduleRender);
</script>
