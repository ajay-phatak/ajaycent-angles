---
import HeaderLink from './HeaderLink.astro';
import Logo from './Logo.astro';
---

<header>
	<nav>
		<Logo size={28} />
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/privacy">Privacy</HeaderLink>
			<a class="external" href="https://elections.ajaycent.com">Election Tracker ↗</a>
		</div>
		<button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
			<svg viewBox="0 0 24 24" class="icon icon-sun" aria-hidden="true">
				<circle cx="12" cy="12" r="4.5" fill="none" stroke="currentColor" stroke-width="1.8" />
				<path
					d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"
				/>
			</svg>
			<svg viewBox="0 0 24 24" class="icon icon-moon" aria-hidden="true">
				<path
					d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linejoin="round"
				/>
			</svg>
		</button>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg-raised);
		border-bottom: 1px solid var(--rule);
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5em;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.6em;
		flex: 1;
		justify-content: flex-end;
	}
	.internal-links :global(a) {
		padding: 1.1em 0;
		color: var(--ink-soft);
		font-weight: 600;
		font-size: 0.92rem;
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	.internal-links :global(a.active) {
		color: var(--ink);
		border-bottom-color: var(--accent);
	}
	a.external {
		padding: 1.1em 0;
		color: var(--accent);
		font-weight: 600;
		font-size: 0.92rem;
		text-decoration: none;
	}
	#theme-toggle {
		border: 1px solid var(--rule);
		background: var(--bg);
		color: var(--ink-soft);
		width: 34px;
		height: 34px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		flex-shrink: 0;
	}
	.icon { width: 18px; height: 18px; }
	.icon-moon { display: none; }
	:global([data-theme='dark']) .icon-sun { display: none; }
	:global([data-theme='dark']) .icon-moon { display: block; }
	@media (max-width: 720px) {
		a.external { display: none; }
		.internal-links { gap: 1.1em; }
	}
</style>
<script is:inline>
	(function () {
		var btn = document.getElementById('theme-toggle');
		if (!btn) return;
		btn.addEventListener('click', function () {
			var root = document.documentElement;
			var current = root.getAttribute('data-theme') || 'light';
			var next = current === 'dark' ? 'light' : 'dark';
			root.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	})();
</script>
