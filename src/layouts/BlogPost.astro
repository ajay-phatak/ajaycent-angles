---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { centered?: boolean };

const { title, description, pubDate, updatedDate, heroImage, centered = false } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				margin: 0 auto;
			}
			.hero-image { width: 100%; max-width: 1020px; margin: 0 auto; }
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow);
			}
			/* 1fr side columns keep the prose centered in the viewport;
			   the ad rail lives in the right one. */
			.layout {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 720px) minmax(0, 1fr);
				gap: 2.5em;
				align-items: start;
				padding: 1em;
			}
			.prose {
				grid-column: 2;
				width: 100%;
				max-width: 720px;
				margin: 0 auto;
			}
			.title { margin-bottom: 1em; padding: 1em 0; text-align: center; line-height: 1.1; }
			.title h1 { margin: 0 0 0.5em 0; font-size: 2.1em; }
			.date { margin-bottom: 0.5em; color: var(--ink-soft); font-size: 0.9rem; }
			.last-updated-on { font-style: italic; }
			aside.ad-rail { grid-column: 3; position: sticky; top: 1.5em; width: auto; }
			@media (max-width: 900px) {
				.layout { grid-template-columns: 1fr; padding: 1em 0.5em; }
				.prose { grid-column: 1; }
				.ad-rail { display: none; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main class:list={[{ centered }]}>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="layout">
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
						<!-- AdSense unit: end of post -->
						<div class="ad-end"></div>
					</div>
					{
						!centered && (
							<aside class="ad-rail" aria-hidden="true">
								<!-- AdSense unit: sidebar -->
							</aside>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
