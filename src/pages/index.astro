---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Logo from '../components/Logo.astro';
import SubscribeBox from '../components/SubscribeBox.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="hero">
			<div class="hero-top">
				<Logo size={56} showWordmark={false} />
				<div>
					<p class="kicker">Tech · Finance · Politics · Philosophy</p>
					<h1>Living on the shared edge.</h1>
				</div>
			</div>
			<p class="lead">
				Essays on the places where technology, markets, politics, and philosophy touch —
				written by Ajay Phatak. Named for <em>adjacent angles</em>: two angles sharing a common
				side, which is usually where the interesting argument happens.
			</p>
			<div class="cta-row">
				<a class="btn btn-primary" href="/blog/">Read the blog</a>
				<a class="btn btn-secondary" href="https://elections.ajaycent.com">2026 Election Tracker ↗</a>
				<a class="btn btn-secondary" href="/support/">Support the site</a>
			</div>
			<SubscribeBox />
		</main>
		<Footer />
	</body>
</html>
<style>
	.hero { padding: 4em 1em 2em; }
	.hero-top {
		display: flex;
		align-items: center;
		gap: 18px;
		margin-bottom: 1.2em;
	}
	.hero-top h1 { margin: 0; font-size: 2.5em; }
	.lead {
		font-size: 1.1rem;
		max-width: 34em;
		margin: 0 0 1.6em;
	}
	.cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
	.hero :global(.subscribe-box) { margin-top: 2.5em; max-width: 34em; }
	@media (max-width: 600px) {
		.hero-top { flex-direction: column; align-items: flex-start; gap: 10px; }
	}
</style>
